# ─── Database ────────────────────────────────────────────────────────────────
# الإنتاج: استخدم DATABASE_URL الذي تُعطيه Railway تلقائياً
# DATABASE_URL=postgresql://user:pass@host:port/db
# التطوير المحلي: استخدم المتغيرات المنفصلة أدناه
DB_NAME=discounts_engine
DB_USER=postgres
DB_PASSWORD=123456
DB_HOST=localhost
DB_PORT=5432

# ─── Telegram Bot ────────────────────────────────────────────────────────────
BOT_TOKEN=

# الإنتاج فقط — webhook
WEBHOOK_SECRET=
WEBHOOK_BASE_URL=https://bot.your-domain.com

# polling | webhook — للتطوير المحلي اضبط RUN_MODE=polling
RUN_MODE=polling

# ─── Cross-service URLs ──────────────────────────────────────────────────────
API_BASE_URL=http://127.0.0.1:8000

# ─── CORS (FastAPI) ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:8000,null

# ─── Bot behavior ────────────────────────────────────────────────────────────
IDLE_TIMEOUT_MINUTES=15
