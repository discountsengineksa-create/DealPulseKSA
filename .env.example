# ─── Database ────────────────────────────────────────────────────────────────
# الإنتاج: استخدم DATABASE_URL الذي تُعطيه Railway تلقائياً
# DATABASE_URL=postgresql://user:pass@host:port/db
# التطوير المحلي: استخدم المتغيرات المنفصلة أدناه
DB_NAME=discounts_engine
DB_USER=postgres
DB_PASSWORD=123456
DB_HOST=localhost
DB_PORT=5432

# ─── Telegram Bot ────────────────────────────────────────────────────────────
BOT_TOKEN=

# الإنتاج فقط — webhook
WEBHOOK_SECRET=
WEBHOOK_BASE_URL=https://bot.your-domain.com

# polling | webhook — للتطوير المحلي اضبط RUN_MODE=polling
RUN_MODE=polling

# ─── Cross-service URLs ──────────────────────────────────────────────────────
API_BASE_URL=http://127.0.0.1:8000

# ─── CORS (FastAPI) ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:8000,null

# اختياري — regex يلتقط Vercel preview URLs (تتغير مع كل deployment).
# الإنتاج (Railway): ^https://[a-z0-9-]+-salah-asiri-s-projects\.vercel\.app$
ALLOWED_ORIGIN_REGEX=

# ─── Bot behavior ────────────────────────────────────────────────────────────
# مرحلتان: تذكير بعد WARN دقيقة، إنهاء جلسة بعد KICK دقيقة
IDLE_WARN_MINUTES=5
IDLE_KICK_MINUTES=10

# ─── Web Auth (FastAPI) ──────────────────────────────────────────────────────
# مطلوب — التطبيق لن يُقلع بدونه. ولّده مرّة واحدة وثبّته:
#   openssl rand -base64 64
JWT_SECRET=

# ─── Cloudinary (شعارات المتاجر — اختياري) ──────────────────────────────────
# اشترك مجاناً على cloudinary.com ثم انسخ القيم من Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (password reset) ──────────────────────────────────────────────────
# الأولوية: RESEND_API_KEY ← SMTP_USER+PASS ← Dev mode (يطبع الكود في الـ logs)
RESEND_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=نبض الصفقات

# ─── Auto-broadcast to Social Platforms ─────────────────────────────────────
# الـ Dashboard يستدعي /api/v1/admin/broadcast/{master_id} بهذا الـ secret.
# ولّد سلسلة طويلة عشوائية (32+ حرف):  openssl rand -base64 32
ADMIN_SHARED_SECRET=
INTERNAL_API_URL=https://dealpulseksa-production.up.railway.app

# Discord (الأبسط — webhook فقط)
DISCORD_WEBHOOK_URL=

# Telegram public channel (يعيد استخدام BOT_TOKEN)
TELEGRAM_CHANNEL_ID=@dealpulse_official

# X (Twitter) — OAuth 1.0a
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Meta (Facebook + Instagram + Threads — كلها Graph API)
FB_PAGE_ID=
IG_BUSINESS_ID=
META_PAGE_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# Pinterest API v5
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

# LinkedIn — UGC Posts API
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=urn:li:person:xxxx

# ─── Redis (Railway plugin يحقن REDIS_URL تلقائياً عند تفعيل البلاجن) ────
# للتطوير المحلي: redis://localhost:6379  (لو ما هو شغّال، الكود يستخدم
# in-memory shim — مناسب للاختبار، ممنوع للإنتاج)
REDIS_URL=

# ─── Financial Guardian (سقف الـ LLM اليومي بالدولار) ───────────────────
DAILY_LLM_BUDGET_USD=5.00
DAILY_LLM_SOFT_THRESHOLD=0.80

# ─── Ops Alerts (بريد الإيميل للتنبيهات التشغيلية) ─────────────────────
# يُرسل عند: تجاوز 80% من سقف LLM، spikes كوبونات، failures حرجة
OPS_ALERT_EMAIL=dealpulesksa@gmail.com

# ─── LLM Provider (Week 3) — Failover: Gemini ← OpenRouter ──────────
# نظام failover ذكي: يحاول Gemini أولاً (الأسرع والأرخص لو متاح في
# منطقتك)، ولو فشل (404/429/quota/network) ينتقل تلقائياً لـ OpenRouter
# (proxy يتجاوز القيود الإقليمية، وفيه free pool واسع).
#
# يكفي تضبط مفتاح واحد على الأقل. لو حاضرين الاثنين، الـ failover يشتغل
# بكامل قوته. لو الأول فقط، فقط هو يُستدعى.

# ─── Primary: Google Gemini Direct ──────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# (اختياري) المودل الافتراضي على Gemini:
#   gemini-2.0-flash       1500 req/day  (default، سريع وذكي)
#   gemini-2.0-flash-lite  1500 req/day  (الأرخص)
#   gemini-2.5-flash       500  req/day  (أقوى استدلال)
#   gemini-2.5-pro         50   req/day  (الأعلى دقة)
# GEMINI_MODEL=gemini-2.0-flash

# ─── Fallback 1: Groq (مجاني + سريع + موثوق — مُوصى به بشدّة) ──────
# مفتاح مجاني خلال دقيقة من https://console.groq.com/keys (بدون بطاقة).
# حدود سخية على Llama 3.3 70B. يُجرَّب بعد Gemini وقبل OpenRouter.
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile   # أو llama-3.1-8b-instant (أسرع)

# ─── Fallback 2: OpenRouter ──────
# https://openrouter.ai/keys (تسجيل بإيميل، بدون credit card)
OPENROUTER_API_KEY=
# (اختياري) المودل الافتراضي على OpenRouter:
#   meta-llama/llama-3.3-70b-instruct:free   ← default (مجاني، مستقر)
#   mistralai/mistral-small-24b-instruct-2501:free (مجاني)
#   google/gemini-2.0-flash-001              ($0.10/$0.40 per 1M)
#   anthropic/claude-3.5-haiku               ($0.80/$4.00 per 1M)
#   openai/gpt-4o-mini                       ($0.15/$0.60 per 1M)
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# سلسلة failover: يجرّب الموديلات بالتتابع لو واحد مات (404) أو امتلأت حصته.
# الافتراضي يغطّي 6 موديلات مجانية. لتخصيص السلسلة كاملةً (مفصولة بفواصل):
# OPENROUTER_MODELS=meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free,qwen/qwen-2.5-72b-instruct:free
# OPENROUTER_HTTP_REFERER=https://dealpulseksa.com
# OPENROUTER_APP_TITLE=DealPulse KSA

# تعديلات اختيارية على دورات الـ workers (الافتراضيات معقولة)
# WORKER_MATVIEW_REFRESH_MIN=1     # تحديث matview بالدقائق
# WORKER_SPIKE_DETECT_MIN=5        # كشف spikes بالدقائق
# WORKER_ALERT_DISPATCH_SEC=30     # إرسال الإيميلات بالثواني
# WORKER_DIRECTIVE_HOURS=3         # تشغيل directive generator بالساعات

# ─── SEO Page Generator (Week 5-6) ───────────────────────────────────
# المرحلتان trends+match مجانيتان وتشتغلان تلقائياً كل 12 ساعة.
# توليد الصفحات عبر الـ LLM يستهلك الميزانية فمُعطّل افتراضياً — فعّله بـ:
# SEO_AUTOGEN_ENABLED=1            # تشغيل توليد الصفحات تلقائياً بالـ scheduler
# SEO_GENERATE_BATCH=3            # عدد الصفحات لكل دورة توليد
# WORKER_SEO_DISCOVERY_HOURS=12   # دورة تجميع الترند + المطابقة
# WORKER_SEO_GENERATE_HOURS=6     # دورة التوليد (فقط لو SEO_AUTOGEN_ENABLED=1)
# مسار صفحة الهبوط على الموقع + إخطار الفهرسة (يلزم route في dealpulseksa-web):
# SITE_URL=https://dealpulseksa.com
# SEO_PAGE_PATH=/c/{slug}
# REVALIDATE_SECRET=               # نفس سر /api/revalidate بالموقع
# INDEXNOW_KEY=                    # مفتاح IndexNow (Bing/Yandex/Naver/Seznam) — يُستضاف ملفه على dealpulseksa-web/public/{KEY}.txt
#                                   # ضعه على Railway (الباكند) + Vercel (الموقع) بنفس القيمة. ملف المفتاح = نفس قيمة المفتاح نصاً.

# ─── Social Listener + Auto-Responder (Week 7-8) ─────────────────────────
# المعالجة (رصد + مطابقة + توليد ردود) تلقائية كل 10 دقائق — مجانية بلا LLM.
# WORKER_SOCIAL_PROCESS_MIN=10     # دورة معالجة الإشارات بالدقائق
# SOCIAL_PROCESS_BATCH=20         # عدد الإشارات لكل دورة
# SOCIAL_RESPOND_MIN_INTENT=0.5   # أدنى نية لتوليد رد
# SOCIAL_AUTO_APPROVE=1           # اعتماد تلقائي للردود عالية الثقة
# SOCIAL_AUTO_APPROVE_MIN_INTENT=0.8
# النشر الفعلي على المنصات: اربط webhook (Zapier/Make/n8n) — وإلا تُعتمد للنسخ اليدوي:
# SOCIAL_POST_WEBHOOK=https://hooks.zapier.com/...
