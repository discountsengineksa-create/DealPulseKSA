# ─── Database ────────────────────────────────────────────────────────────────
# الإنتاج: استخدم DATABASE_URL الذي تُعطيه Railway تلقائياً
# DATABASE_URL=postgresql://user:pass@host:port/db
# التطوير المحلي: استخدم المتغيرات المنفصلة أدناه
DB_NAME=discounts_engine
DB_USER=postgres
DB_PASSWORD=123456
DB_HOST=localhost
DB_PORT=5432

# ─── Telegram Bot ────────────────────────────────────────────────────────────
BOT_TOKEN=

# الإنتاج فقط — webhook
WEBHOOK_SECRET=
WEBHOOK_BASE_URL=https://bot.your-domain.com

# polling | webhook — للتطوير المحلي اضبط RUN_MODE=polling
RUN_MODE=polling

# ─── Cross-service URLs ──────────────────────────────────────────────────────
API_BASE_URL=http://127.0.0.1:8000

# ─── CORS (FastAPI) ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:8000,null

# ─── Bot behavior ────────────────────────────────────────────────────────────
# مرحلتان: تذكير بعد WARN دقيقة، إنهاء جلسة بعد KICK دقيقة
IDLE_WARN_MINUTES=5
IDLE_KICK_MINUTES=10

# ─── Web Auth (FastAPI) ──────────────────────────────────────────────────────
# مطلوب — التطبيق لن يُقلع بدونه. ولّده مرّة واحدة وثبّته:
#   openssl rand -base64 64
JWT_SECRET=

# ─── Cloudinary (شعارات المتاجر — اختياري) ──────────────────────────────────
# اشترك مجاناً على cloudinary.com ثم انسخ القيم من Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (password reset) ──────────────────────────────────────────────────
# الأولوية: RESEND_API_KEY ← SMTP_USER+PASS ← Dev mode (يطبع الكود في الـ logs)
RESEND_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=نبض الصفقات

# ─── Auto-broadcast to Social Platforms ─────────────────────────────────────
# الـ Dashboard يستدعي /api/v1/admin/broadcast/{master_id} بهذا الـ secret.
# ولّد سلسلة طويلة عشوائية (32+ حرف):  openssl rand -base64 32
ADMIN_SHARED_SECRET=
INTERNAL_API_URL=https://dealpulseksa-production.up.railway.app

# Discord (الأبسط — webhook فقط)
DISCORD_WEBHOOK_URL=

# Telegram public channel (يعيد استخدام BOT_TOKEN)
TELEGRAM_CHANNEL_ID=@dealpulse_official

# X (Twitter) — OAuth 1.0a
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Meta (Facebook + Instagram + Threads — كلها Graph API)
FB_PAGE_ID=
IG_BUSINESS_ID=
META_PAGE_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# Pinterest API v5
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

# LinkedIn — UGC Posts API
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=urn:li:person:xxxx

# ─── Redis (Railway plugin يحقن REDIS_URL تلقائياً عند تفعيل البلاجن) ────
# للتطوير المحلي: redis://localhost:6379  (لو ما هو شغّال، الكود يستخدم
# in-memory shim — مناسب للاختبار، ممنوع للإنتاج)
REDIS_URL=

# ─── Financial Guardian (سقف الـ LLM اليومي بالدولار) ───────────────────
DAILY_LLM_BUDGET_USD=5.00
DAILY_LLM_SOFT_THRESHOLD=0.80

# ─── Ops Alerts (بريد الإيميل للتنبيهات التشغيلية) ─────────────────────
# يُرسل عند: تجاوز 80% من سقف LLM، spikes كوبونات، failures حرجة
OPS_ALERT_EMAIL=dealpulesksa@gmail.com

# ─── OpenRouter (Week 3 — directive generator) ─────────────────────
# OpenRouter يعمل كـ proxy لجميع المزوّدين (Google, Anthropic, OpenAI,
# Meta, Mistral...) بـ OpenAI-compatible API. يتجاوز قيود Gemini الإقليمية.
# احصل عليه من: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# (اختياري) تغيير المودل الافتراضي:
#   meta-llama/llama-3.3-70b-instruct:free ← default (مجاني، مستقر، 70B)
#   mistralai/mistral-small-24b-instruct-2501:free (مجاني)
#   google/gemini-2.0-flash-001            ($0.10/$0.40 per 1M tokens)
#   anthropic/claude-3.5-haiku             ($0.80/$4.00 per 1M)
#   openai/gpt-4o-mini                     ($0.15/$0.60 per 1M)
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# (اختياري) Headers الـ OpenRouter للتعريف بالـ app
# OPENROUTER_HTTP_REFERER=https://dealpulseksa.com
# OPENROUTER_APP_TITLE=DealPulse KSA

# تعديلات اختيارية على دورات الـ workers (الافتراضيات معقولة)
# WORKER_MATVIEW_REFRESH_MIN=1     # تحديث matview بالدقائق
# WORKER_SPIKE_DETECT_MIN=5        # كشف spikes بالدقائق
# WORKER_ALERT_DISPATCH_SEC=30     # إرسال الإيميلات بالثواني
# WORKER_DIRECTIVE_HOURS=3         # تشغيل directive generator بالساعات
