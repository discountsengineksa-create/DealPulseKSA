# انسخ هذا الملف إلى .streamlit/secrets.toml وعدّل القيم
# للإنتاج على Railway: أضف نفس البنية في Settings > Variables للـ dashboard service
#
# لتوليد bcrypt hash لكلمة سر:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"

[auth]
cookie_name = "deal_pulse_admin"
cookie_key = "REPLACE_WITH_RANDOM_32_CHARS"
cookie_expiry_days = 1

[auth.credentials.usernames.admin]
name = "Admin"
email = "admin@dealpulse.local"
password = "REPLACE_WITH_BCRYPT_HASH"
